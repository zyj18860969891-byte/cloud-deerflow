# DeerFlow 生产环境配置示例
# 复制此文件为 .env.production 并填写实际值

# ============================================================================
# 认证配置（必须修改！）
# ============================================================================
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-change-this-in-production

# ============================================================================
# LLM API Keys（必须填写）
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# 可选：其他提供商
# GOOGLE_API_KEY=your-google-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================================================
# 数据库配置（生产环境建议使用PostgreSQL）
# ============================================================================
# 如果使用Docker Compose部署，这些值会覆盖docker-compose中的配置
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=deerflow
# DB_USER=deerflow
# DB_PASSWORD=your-secure-db-password

# ============================================================================
# Redis 配置（用于缓存和会话）
# ============================================================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================================
# 多租户配置
# ============================================================================
# 启用多租户功能
DEER_FLOW_MULTI_TENANT_ENABLED=true
# 租户隔离级别：data|resource|strict
DEER_FLOW_TENANT_ISOLATION_LEVEL=strict

# ============================================================================
# 服务端点配置
# ============================================================================
# 内部服务通信URL（Docker网络内部）
DEER_FLOW_CHANNELS_LANGGRAPH_URL=http://langgraph:2024
DEER_FLOW_CHANNELS_GATEWAY_URL=http://gateway:8001

# ============================================================================
# 路径配置（通常使用默认值即可）
# ============================================================================
DEER_FLOW_HOME=/data/deer-flow/.deer-flow
DEER_FLOW_CONFIG_PATH=/app/backend/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/data/deer-flow/.deer-flow/extensions_config.json
DEER_FLOW_REPO_ROOT=/opt/deer-flow
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock

# ============================================================================
# 性能调优
# ============================================================================
# Web服务器并发数（根据CPU核心数调整）
WEB_CONCURRENCY=4

# 数据库连接池大小
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# 缓存配置
CACHE_TTL=3600
ENABLE_QUERY_CACHE=true

# ============================================================================
# 监控和日志
# ============================================================================
# 日志级别：DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# LangSmith追踪（可选，用于调试）
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key

# ============================================================================
# 安全配置
# ============================================================================
# 允许的主机名（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS配置（前端URL，逗号分隔）
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ============================================================================
# 通道配置（可选）
# ============================================================================
# 飞书应用
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ============================================================================
# 邮件通知（可选）
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_FROM=your-email@gmail.com

# ============================================================================
# 备份配置
# ============================================================================
# 自动备份保留天数
BACKUP_RETENTION_DAYS=30
# 备份时间（cron格式）
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点

# ============================================================================
# 租户特定配置（多租户模式）
# ============================================================================
# 默认租户限制
DEFAULT_TENANT_MAX_THREADS=1000
DEFAULT_TENANT_MAX_MESSAGES_PER_THREAD=10000
DEFAULT_TENANT_MAX_API_CALLS_PER_DAY=100000
DEFAULT_TENANT_MAX_CONCURRENT_REQUESTS=50

# ============================================================================
# Docker配置
# ============================================================================
# 端口映射（默认2026）
PORT=2026

# Docker Compose项目名
COMPOSE_PROJECT_NAME=deer-flow

# 构建参数（可选）
# APT_MIRROR=mirrors.aliyun.com
# NPM_REGISTRY=https://registry.npmmirror.com
# PNPM_STORE_PATH=/root/.local/share/pnpm/store